{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowJITElevationWithinWindow",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::123456789012:role/StandardOperator"
      },
      "Action": [
        "sts:AssumeRole",
        "sts:TagSession"
      ],
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        },
        "NumericLessThan": {
          "aws:MultiFactorAuthAge": "900"
        },
        "DateGreaterThan": {
          "aws:CurrentTime": "2026-05-05T14:00:00Z"
        },
        "DateLessThan": {
          "aws:CurrentTime": "2026-05-05T15:00:00Z"
        },
        "StringEquals": {
          "sts:ExternalId": "elevation-ticket-INC0012345"
        },
        "IpAddress": {
          "aws:SourceIp": [
            "10.100.0.0/16",
            "203.0.113.0/24"
          ]
        },
        "StringLike": {
          "aws:RequestTag/ElevationTicket": "INC0*"
        },
        "StringEquals": {
          "aws:RequestTag/ApprovedBy": [
            "security-oncall",
            "platform-oncall"
          ]
        },
        "ForAllValues:StringEquals": {
          "aws:TagKeys": [
            "ElevationTicket",
            "ApprovedBy",
            "Justification"
          ]
        },
        "NumericLessThanEquals": {
          "sts:DurationSeconds": "3600"
        }
      }
    },
    {
      "Sid": "DenyAssumeOutsideWindow",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "sts:AssumeRole",
      "Condition": {
        "DateGreaterThan": {
          "aws:CurrentTime": "2026-05-05T15:00:00Z"
        }
      }
    },
    {
      "Sid": "DenyAssumeBeforeWindow",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "sts:AssumeRole",
      "Condition": {
        "DateLessThan": {
          "aws:CurrentTime": "2026-05-05T14:00:00Z"
        }
      }
    }
  ]
}
